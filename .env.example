# POS System Environment Configuration
# Copy this file to .env and update values

# ===========================================
# DATABASE CONFIGURATION
# ===========================================

# System Database URL (for authentication, users, companies, menus, roles)
# This database stores shared system-level data
SYSTEM_DATABASE_URL="mysql://root:password@localhost:3306/system_db"

# Base Database URL (used for tenant database connections)
# The tenant database name will be derived from company data (e.g., tenant_1, tenant_2)
DATABASE_URL="mysql://root:password@localhost:3306/restaurant_tenant"

# ===========================================
# JWT CONFIGURATION
# ===========================================

# JWT Secret Key (use a strong random string in production)
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# Token expiration times
JWT_EXPIRES_IN="24h"
JWT_REFRESH_EXPIRES_IN="7d"

# ===========================================
# SERVER CONFIGURATION
# ===========================================

# Server port
PORT=5000

# Node environment (development, production, test)
NODE_ENV=development

# ===========================================
# CORS CONFIGURATION
# ===========================================

# Allowed origins
CORS_ORIGIN="http://localhost:5173"

# ===========================================
# RATE LIMITING
# ===========================================

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=10
REPORT_RATE_LIMIT_MAX=20

# ===========================================
# OTP & EMAIL CONFIGURATION
# ===========================================

# OTP expiry time in minutes
OTP_EXPIRY_MINUTES=10

# Email configuration (for sending OTP)
# For TESTING: Use https://ethereal.email/create to get free test credentials
# View test emails at: https://ethereal.email/messages
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=your.name@ethereal.email
SMTP_PASS=yourEtherealPassword

# ===========================================
# STRIPE PAYMENT GATEWAY
# ===========================================

# For TESTING: Use Stripe test mode keys
# Get keys from: https://dashboard.stripe.com/test/apikeys
# Test card number: 4242 4242 4242 4242 (any future expiry, any CVC)
STRIPE_SECRET_KEY=sk_test_your_test_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ===========================================
# FILE UPLOAD CONFIGURATION
# ===========================================

# Upload directory
UPLOAD_DIR=./uploads

# Maximum file size in bytes (5MB)
MAX_FILE_SIZE=5242880

# ===========================================
# MULTI-TENANCY NOTES
# ===========================================

# The system uses schema-based multi-tenancy:
# 1. system_db - Stores: users, companies, roles, permissions, menus, templates
# 2. tenant_{id} - Stores: branches, products, orders, inventory, accounting
#
# When a new user registers:
# 1. A SystemUser is created in system_db
# 2. A Company is created in system_db
# 3. After OTP verification, a tenant database (tenant_{company_id}) is created
# 4. Default roles, branches, and accounts are seeded in the tenant database
#
# The master user (first user of a company) can:
# - Create branches
# - Create users and assign them to branches
# - Create custom roles with granular permissions
# - Access all branches in their company
#
# Branch users can only access their assigned branch with role-based permissions
